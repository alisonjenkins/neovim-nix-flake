+            .read_message()
+            .await
+            .context("receive initialize response")?
+            .context("stream ended")?
+        {
+            Message::ResponseSuccess(res) if res.id == request_id => break res,
+            Message::Notification(n) => {
+                tracing::debug!(method = %n.method, "discarding pre-initialize notification");
+                continue;
+            }
+            _ => bail!("first server response was not initialize response"),
+        }
