# Custom .envrc that skips nix-direnv's per-flake-input gcroot loop.
# Stock `use flake` runs `nix build --out-link` once per flake.lock input,
# which dominates cold reload time. The dev shell derivation stays gcroot-
# protected via the profile symlink; only eval-time flake input source
# paths become unprotected, so a subsequent `nix-collect-garbage` may
# re-fetch them on the next reload.

watch_file flake.nix flake.lock

layout_dir="$(direnv_layout_dir)"
profile="$layout_dir/devshell-profile"
profile_rc="$profile.rc"

needs_update=0
if [[ ! -e $profile || ! -e $profile_rc ]]; then
  needs_update=1
else
  for f in flake.nix flake.lock; do
    if [[ -e $f && $f -nt $profile_rc ]]; then
      needs_update=1
      break
    fi
  done
fi

if [[ $needs_update -eq 1 ]]; then
  log_status "rebuilding dev shell profile"
  mkdir -p "$layout_dir"
  if rc_contents=$(nix --no-warn-dirty --accept-flake-config \
      --extra-experimental-features "nix-command flakes" \
      print-dev-env --profile "$profile" .); then
    printf '%s\n' "$rc_contents" > "$profile_rc"
  else
    log_error "nix print-dev-env failed"
    return 1
  fi
fi

[[ -e $profile_rc ]] && eval "$(<"$profile_rc")"
